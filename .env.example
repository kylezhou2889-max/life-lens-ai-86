# Google Gemini API Configuration
# Get your API key from: https://ai.google.dev/
# 1. Visit https://ai.google.dev/
# 2. Click "Get API Key" and create a new key in Google Cloud Console
# 3. Copy your API key and paste it below
# 4. IMPORTANT: This file is for reference only. Create a .env.local file for actual deployment
#    and add it to .gitignore to prevent exposing your API key

VITE_GEMINI_API_KEY=your_gemini_api_key_here
